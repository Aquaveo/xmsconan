<% if ci_deploy %>
# Required CI/CD variables:
#   AQUAPI_URL      - devpi index URL for wheel uploads
#   AQUAPI_USERNAME - devpi username for wheel uploads
#   AQUAPI_PASSWORD - devpi password for wheel uploads
#
<% endif %>
# Generated by xmsconan_ci — do not edit manually.

stages:
<% if ci_split_tests %>
  - Build
<% endif %>
  - Test
  - Package
<% if ci_deploy %>
  - Deploy
<% endif %>
<% if ci_coverage %>
  - Coverage
  - Pages
<% endif %>

<% if ci_deploy %>
variables:
  DEFAULT_VERSION: "0.0.0"
  PACKAGE_VERSION: "${CI_COMMIT_TAG:-$DEFAULT_VERSION}"

<% endif %>
Conan Build:
<% if ci_split_tests %>
  stage: Build
<% else %>
  stage: Test
<% endif %>
<% if docker_image %>
  image: << docker_image >>
<% elif ci_xvfb %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-x11-gdal-py3.13
<% else %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-py3.13
<% endif %>
  variables:
    PYTHON_TARGET_VERSION: '3.13'
  artifacts:
    expire_in: '1d'
    when: always
    paths:
<% if ci_deploy %>
      - .export
<% endif %>
      - wheelhouse/
      - test_artifacts/
  script:
    - gcc --version
    - cmake --version
    - python --version
    - pip install conan xmsconan>=<< xmsconan_version >> -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_conan_setup
    - export PACKAGE_VERSION=${CI_COMMIT_TAG:-0.0.0}
    - export CTEST_PARALLEL_LEVEL=${CTEST_PARALLEL_LEVEL:-8}
<% if ci_split_tests %>
    - export XMS_SKIP_CXX_TESTS=1
<% endif %>
    - xmsconan_gen --version ${PACKAGE_VERSION} build.toml
<% if ci_xvfb %>
    - xvfb-run -a -s "-screen 0 1280x1024x24" python build.py --version ${PACKAGE_VERSION} --wheel-dir wheelhouse --artifacts-dir test_artifacts
<% else %>
    - python build.py --version ${PACKAGE_VERSION} --wheel-dir wheelhouse --artifacts-dir test_artifacts
<% endif %>
<% if ci_deploy %>
    - xmsconan_conan_deploy << library_name >> ${PACKAGE_VERSION} --save .export/<< library_name >>-linux-${PACKAGE_VERSION}.tar.gz
<% endif %>

<% if ci_split_tests %>
"Run C++ Tests":
  stage: Test
<% if docker_image %>
  image: << docker_image >>
<% elif ci_xvfb %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-x11-gdal-py3.13
<% else %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-py3.13
<% endif %>
<% if ci_test_shards > 1 %>
  parallel: << ci_test_shards >>
<% endif %>
  except:
    - tags
  needs:
    - job: "Conan Build"
      artifacts: true
  artifacts:
    expire_in: '1d'
    when: always
    paths:
      - test_artifacts/
  script:
    - export CTEST_PARALLEL_LEVEL=${CTEST_PARALLEL_LEVEL:-8}
<% if ci_test_shards > 1 %>
    - export GTEST_TOTAL_SHARDS=<< ci_test_shards >>
    - export GTEST_SHARD_INDEX=$((CI_NODE_INDEX - 1))
<% endif %>
    - |
      ARTIFACT_DIR=$(ls -d test_artifacts/*-testing 2>/dev/null | head -1)
      if [ -z "$ARTIFACT_DIR" ]; then
        echo "ERROR: No testing artifacts found in test_artifacts/"
        exit 1
      fi
      RUNNER="$ARTIFACT_DIR/runner"
      if [ ! -f "$RUNNER" ]; then
        echo "ERROR: Runner binary not found at $RUNNER"
        exit 1
      fi
      chmod +x "$RUNNER"
      # Reconstruct test_files at the compiled-in path
      if [ -f "$ARTIFACT_DIR/test_metadata.json" ]; then
        TEST_PATH=$(python3 -c "import json; print(json.load(open('$ARTIFACT_DIR/test_metadata.json'))['test_path'])")
        mkdir -p "$(dirname "$TEST_PATH")"
        if [ -d "$ARTIFACT_DIR/test_files" ]; then
          ln -sfn "$(pwd)/$ARTIFACT_DIR/test_files" "${TEST_PATH%/}"
        fi
      fi
<% if ci_xvfb and ci_test_shards > 1 %>
    - DISPLAY_NUM=$((99 + CI_NODE_INDEX))
    - xvfb-run --server-num=${DISPLAY_NUM} -s "-screen 0 1280x1024x24" "$ARTIFACT_DIR/runner" --gtest_output=xml:TEST-cxxtest.xml
<% elif ci_xvfb %>
    - xvfb-run -a -s "-screen 0 1280x1024x24" "$ARTIFACT_DIR/runner" --gtest_output=xml:TEST-cxxtest.xml
<% else %>
    - "$ARTIFACT_DIR/runner" --gtest_output=xml:TEST-cxxtest.xml
<% endif %>

<% endif %>
<% if ci_windows %>
"Conan Build - Windows":
<% if ci_split_tests %>
  stage: Build
<% else %>
  stage: Test
<% endif %>
  image: GLR-${PY_TAG}
  parallel:
    matrix:
<% for v in ci_python_versions %>
      - PYTHON_TARGET_VERSION: '<< v >>'
        PY_TAG: 'py<< v | replace(".", "") >>'
<% endfor %>
  variables:
    AQUAPI_URL: "https://aquapi.aquaveo.com/aquaveo/dev"
  artifacts:
    expire_in: '1d'
    when: always
    paths:
      - .export
      - test_artifacts/
  script:
    - export PACKAGE_VERSION=${CI_COMMIT_TAG:-0.0.0}
    - export CTEST_PARALLEL_LEVEL=${CTEST_PARALLEL_LEVEL:-8}
    - echo ${PACKAGE_VERSION}
    - python --version
    - pip install conan toml packaging devpi-client
    - python -m pip install --upgrade "xmsconan>=<< xmsconan_version >>" -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_conan_setup
    - xmsconan_gen --version ${PACKAGE_VERSION} build.toml
    - python build.py --version ${PACKAGE_VERSION} --artifacts-dir test_artifacts
    - xmsconan_conan_deploy << library_name >> ${PACKAGE_VERSION} --save .export/<< library_name >>-windows-py${PYTHON_TARGET_VERSION}-${PACKAGE_VERSION}.tar.gz
  tags:
    - WinVM

<% endif %>
Lint:
  stage: Test
  image: python:3.13
  allow_failure: true
  script:
    - pip install flake8 flake8-docstrings flake8-bugbear flake8-import-order pep8-naming flake8-colors flake8-tidy-imports
    - pip install -i https://aquapi.aquaveo.com/aquaveo/dev/+simple/ flake8-aquaveo
    - pip install --upgrade "xmsconan>=<< xmsconan_version >>" -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_gen --version 0.0.0 build.toml
    - flake8 _package

Repair Wheel:
  stage: Package
<% if docker_image %>
  image: << docker_image >>
<% elif ci_xvfb %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-x11-gdal-py3.13
<% else %>
  image: quay.io/pypa/manylinux_2_28_x86_64
<% endif %>
  dependencies:
    - Conan Build
  script:
    - /opt/python/cp313-cp313/bin/pip install --upgrade "xmsconan>=<< xmsconan_version >>" -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - /opt/python/cp313-cp313/bin/xmsconan_wheel_repair --wheel-dir wheelhouse
  artifacts:
    expire_in: '1d'
    paths:
      - wheelhouse/

<% if ci_deploy %>
"Wheel Deploy":
  stage: Deploy
  image: python:3.13
  dependencies:
    - Repair Wheel
  script:
    - pip install --upgrade "xmsconan>=<< xmsconan_version >>" -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_wheel_deploy --wheel-dir wheelhouse
  only:
    - tags

"Conan Deploy - Linux":
  stage: Deploy
  image: ubuntu:latest
  dependencies:
    - Conan Build
  script:
    - apt-get update
    - apt-get install -y python3-pip python3-venv
    - python3 -m venv .venv
    - source .venv/bin/activate
    - pip install conan xmsconan>=<< xmsconan_version >> -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_conan_setup
    - export PACKAGE_VERSION=${CI_COMMIT_TAG:-0.0.0}
    - xmsconan_conan_deploy << library_name >> ${PACKAGE_VERSION} --restore .export/<< library_name >>-linux-${PACKAGE_VERSION}.tar.gz --upload
  only:
    - tags

<% if ci_windows %>
"Conan Deploy - Windows":
  stage: Deploy
  image: GLR-${PY_TAG}
  parallel:
    matrix:
<% for v in ci_python_versions %>
      - PYTHON_TARGET_VERSION: '<< v >>'
        PY_TAG: 'py<< v | replace(".", "") >>'
<% endfor %>
  needs:
    - job: "Conan Build - Windows"
      parallel:
        matrix:
          - PYTHON_TARGET_VERSION: $PYTHON_TARGET_VERSION
      artifacts: true
  artifacts:
    expire_in: '1d'
    paths:
      - conan_packages/
  script:
    - export PACKAGE_VERSION=${CI_COMMIT_TAG:-0.0.0}
    - pip install conan xmsconan>=<< xmsconan_version >> -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_conan_setup
    - xmsconan_conan_deploy << library_name >> ${PACKAGE_VERSION} --restore .export/<< library_name >>-windows-py${PYTHON_TARGET_VERSION}-${PACKAGE_VERSION}.tar.gz --upload
    - mkdir -p conan_packages
    - cp -r /c/Users/admin/.conan2/p/* conan_packages/ || true
  only:
    - tags
  tags:
    - WinVM
<% endif %>
<% endif %>

<% if ci_coverage %>
Coverage:
  stage: Coverage
<% if ci_split_tests %>
  allow_failure: true
<% endif %>
  except:
    - tags
<% if docker_image %>
  image: << docker_image >>
<% elif ci_xvfb %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-x11-gdal-py3.13
<% else %>
  image: docker.aquaveo.com/aquaveo/conan-docker/conan-gcc13-py3.13
<% endif %>
  script:
    - pip install conan "gcovr>=7,<9"
    - pip install --upgrade "xmsconan>=<< xmsconan_version >>" -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple
    - xmsconan_conan_setup
    - export CTEST_PARALLEL_LEVEL=${CTEST_PARALLEL_LEVEL:-8}
    - export PACKAGE_VERSION=${CI_COMMIT_TAG:-0.0.0}
    - xmsconan_coverage --version ${PACKAGE_VERSION} build.toml
  artifacts:
    reports:
      coverage_report:
        coverage_format: cobertura
        path: cov-cpp.xml
    paths:
      - cov-cpp.xml
      - cov-py.xml
      - coverage-html-cpp/
      - coverage-html-py/
  coverage: '/TOTAL.*\s+(\d+%)/'

pages:
  stage: Pages
  dependencies:
    - Coverage
  script:
    - mkdir -p public
    - cp -r coverage-html-cpp public/cpp
    - HAS_PY=0
    - if [ -d coverage-html-py ]; then cp -r coverage-html-py public/python; HAS_PY=1; fi
    - |
      {
        echo '<!DOCTYPE html>'
        echo '<html lang="en"><head><meta charset="utf-8">'
        echo '<title><< library_name >> coverage</title></head><body>'
        echo '<h1><< library_name >> coverage</h1>'
        echo '<ul>'
        echo '<li><a href="cpp/index.html">C++ coverage (gcovr)</a></li>'
        [ "$HAS_PY" -eq 1 ] && echo '<li><a href="python/index.html">Python coverage (pytest-cov)</a></li>'
        echo '</ul></body></html>'
      } > public/index.html
  artifacts:
    paths:
      - public
  only:
    - master
    - main
<% endif %>
