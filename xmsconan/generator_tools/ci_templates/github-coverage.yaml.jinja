# Generated by xmsconan_ci — do not edit manually.

name: << display_name >>-Coverage

on:
  push:
  pull_request:

jobs:
  coverage:
    name: Coverage (Linux)
    runs-on: ubuntu-latest

<% if docker_image %>
    container:
      image: << docker_image >>
<% elif ci_xvfb %>
    container:
      image: ghcr.io/aquaveo/conan-gcc13-x11-gdal-py3.13:latest
<% else %>
    container:
      image: ghcr.io/aquaveo/conan-gcc13-py3.13:latest
<% endif %>

    env:
      LIBRARY_NAME: << library_name >>
      XMS_VERSION: '0.0.0'
      CONAN_LOGIN_USERNAME: ${{ secrets.CONAN2_USER_SECRET }}
      CONAN_PASSWORD: ${{ secrets.CONAN2_PASSWORD_SECRET }}
      CONAN_REMOTE_URL: https://conan2.aquaveo.com/artifactory/api/conan/aquaveo-stable
      AQUAPI_USERNAME: ${{ secrets.AQUAPI_USERNAME_SECRET }}
      AQUAPI_PASSWORD: ${{ secrets.AQUAPI_PASSWORD_SECRET }}
      AQUAPI_URL: ${{ secrets.AQUAPI_URL_DEV }}
      PYTHON_TARGET_VERSION: '3.13'
      CTEST_PARALLEL_LEVEL: '8'

    steps:
      - name: Checkout Source
        uses: actions/checkout@v2

      - name: Install Python Dependencies
        run: |
          pip install conan wheel gcovr
          pip install xmsconan>=<< xmsconan_version >> -i https://public.aquapi.aquaveo.com/aquaveo/dev/+simple

      - name: Setup Conan
        run: xmsconan_conan_setup --remote-url ${{ env.CONAN_REMOTE_URL }} --login
        shell: bash

      - name: Run Coverage
        run: xmsconan_coverage --version ${{ env.XMS_VERSION }} build.toml
        shell: bash

      - name: Upload Coverage HTML
        uses: actions/upload-artifact@v4
        with:
          name: coverage-html
          path: |
            coverage-html-cpp/
            coverage-html-py/
          if-no-files-found: ignore
        if: always()

      - name: Upload Coverage XML
        uses: actions/upload-artifact@v4
        with:
          name: coverage-xml
          path: |
            cov-cpp.xml
            cov-py.xml
          if-no-files-found: ignore
        if: always()
